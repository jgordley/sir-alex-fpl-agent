# ---------------------------------------------------------------------------
# Local Sigil run for `python experiment.py`.
#
# Local Sigil runs all components in one process on :8080, so there's NO Cloud
# gateway, NO plugin proxy, and NO service-account token. Generations,
# experiments, and scores all go straight to http://localhost:8080 with a simple
# tenant header — and scores publish for real (no SKIP_SCORES needed).
#
#   cp .env.experiment.local .env        # or: set -a; source .env.experiment.local
#   PYTHONPATH=. python experiment.py
# ---------------------------------------------------------------------------

# --- Model (Anthropic, direct) ---------------------------------------------
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-haiku-4-5-20251001

# --- Local Sigil (single process on :8080) ---------------------------------
# Generation ingest endpoint. The experiment/score control calls reuse this
# host (the SDK strips the path), so everything targets http://localhost:8080.
SIGIL_ENDPOINT=http://localhost:8080/api/v1/generations:export
SIGIL_PROTOCOL=http
# Local Sigil uses the fake dev tenant (SIGIL_FAKE_TENANT_ID=fake in its compose).
SIGIL_AUTH_MODE=tenant
SIGIL_AUTH_TENANT_ID=fake

SIGIL_AGENT_NAME=sir-alex-fpl
SIGIL_AGENT_VERSION=1.0.0

# --- IMPORTANT: do NOT set SIGIL_EVAL_* for local ---------------------------
# With these unset, the SDK sends experiments + scores directly to
# http://localhost:8080 (api endpoint) with the tenant header above — exactly
# what the all-in-one local stack serves. Setting them would wrongly route to a
# Grafana plugin proxy that doesn't exist locally.
# SIGIL_EVAL_ENDPOINT=
# SIGIL_EVAL_PATH_PREFIX=
# SIGIL_EVAL_AUTH_TOKEN=

# --- Protected eval endpoints (experiment create/finalize) ------------------
# The /api/v1/eval/* endpoints require a trusted actor. Locally that's provided
# by running Sigil in development mode, which defaults the actor to
# system@grafana.com:
#
#   DEVELOPMENT=true docker compose --profile core up --build -d   (in the sigil repo)
#
# If your local Sigil is NOT in development mode, uncomment the next line instead
# to supply the actor headers yourself (safe locally — there's no proxy to strip
# them):
# SIGIL_HEADERS=X-Grafana-User=local@dev,X-Sigil-Trusted-Actor=true

# Optional: stable run id (otherwise a timestamp is used).
# RUN_ID=sir-alex-fpl-local

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the base URL (defaults to https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AWS Configuration for AgentCore Memory
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-west-2

# AgentCore Memory
AGENTCORE_MEMORY_ID=your_memory_id_here
AGENTCORE_PREFERENCE_STRATEGY_ID=your_preference_strategy_id_here

# Semantic Query Generation Model (for preference retrieval)
SEMANTIC_QUERY_MODEL_ID=anthropic/claude-haiku-3.5

# Allowed Users (comma-separated list of valid actor IDs)
ALLOWED_USERS=user1,user2,user3

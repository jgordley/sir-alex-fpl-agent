# ---------------------------------------------------------------------------
# Env for `python experiment.py` (Sir Alex FPL Sigil experiment).
# Copy to .env (or `set -a; source this file`) and fill in the blanks.
#
#   cp .env.experiment.sample .env        # or merge into your existing .env
#   PYTHONPATH=. python experiment.py
# ---------------------------------------------------------------------------

# --- Model (Anthropic, direct — not OpenRouter) ----------------------------
# Anthropic API key for both the agent and the LLM judge.
ANTHROPIC_API_KEY=sk...
# Optional: override the agent + judge model (Anthropic model id).
AGENT_MODEL=claude-haiku-4-5-20251001

# --- Sigil on Grafana Cloud ------------------------------------------------
# Ingest API URL from: Grafana Cloud → Observability → AI Observability →
# Configuration. Looks like https://sigil-prod-<region>.grafana.net.
# Used for INGEST only: generation export and score export (tenant auth).
# The experiment control plane is configured separately below.
SIGIL_ENDPOINT=https://sigil-prod-us-east-0.grafana.net

# Grafana Cloud talks HTTP with basic auth.
SIGIL_PROTOCOL=http
SIGIL_AUTH_MODE=basic
# Basic-auth username = your Grafana Cloud instance / stack (tenant) ID (numeric).
SIGIL_AUTH_TENANT_ID=1572190
# Basic-auth password = Grafana Cloud Access Policy Token (glc_...) with the
# `sigil:write` scope.
SIGIL_AUTH_TOKEN=

# Optional: how the run is labeled in Sigil.
SIGIL_AGENT_NAME=sir-alex-fpl
SIGIL_AGENT_VERSION=1.0.0

# --- Experiment control plane (different host + auth than ingest!) ---------
# The eval/experiment endpoints (/api/v1/eval/*) are PROTECTED: on Grafana Cloud
# they are reachable only through the Grafana plugin resource proxy, which
# authenticates a Grafana identity and injects the trusted-actor headers Sigil
# requires. The access-policy token above is for INGEST only (generations +
# scores) and will get "401 invalid scope" on the eval endpoints.
#
# So the experiment control plane uses your Grafana STACK URL + the plugin
# resource path + a Grafana SERVICE ACCOUNT token (sent as Bearer):
#
# Your Grafana stack base URL (the UI host, e.g. https://<stack>.grafana.net).
SIGIL_EVAL_ENDPOINT=
# Fixed: the Sigil plugin's resource proxy prefix.
SIGIL_EVAL_PATH_PREFIX=/api/plugins/grafana-sigil-app/resources
# Grafana service account token (glsa_...). The service account needs access to
# the Sigil app / eval write. This is NOT the glc_ access-policy token.
SIGIL_EVAL_AUTH_TOKEN=

# --- Nice-to-haves ---------------------------------------------------------
# The "View in Sigil" link is derived from SIGIL_EVAL_ENDPOINT (your stack URL),
# so it should already be correct. Override here only if needed; {run_id} is
# substituted.
# SIGIL_EXPERIMENT_URL_TEMPLATE=https://{stack_name}.grafana.net/a/grafana-sigil-app/evaluation/experiments/{run_id}

# Optional: stable run id so CI retries are idempotent (defaults to a timestamp).
# RUN_ID=sir-alex-fpl-pr-123
